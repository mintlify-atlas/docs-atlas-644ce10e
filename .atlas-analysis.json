  "keyFeatures": [
    "Entity Component System (ECS) architecture",
    "Rollback and delay-based netcode for smooth multiplayer",
    "Dual rendering support (Three.js for 3D, Pixi.js for 2D)",
    "Physics engines (Rapier 2D and 3D)",
    "Game builder system for creating new game modes",
    "Websocket-based multiplayer server with Prisma database",
    "Built-in UI components and HTML overlays",
    "10+ playable game modes included",
    "TypeScript-first with strict typing",
    "Monorepo structure with Bun workspaces"
  ],
  "publicApiSurface": [
    "World - Core runtime managing tick loop, entities, and systems",
    "DefaultWorld - Pre-configured world with base systems",
    "Game & GameBuilder - Game mode definition and initialization",
    "Component - ECS component definitions",
    "System & SystemBuilder - ECS system definitions",
    "Entity - Game object with components",
    "ThreeRenderer - 3D rendering engine",
    "PixiRenderer - 2D rendering engine",
    "Client - Multiplayer client connection",
    "DelaySyncer - Delay-based netcode",
    "RollbackSyncer - Rollback netcode for competitive games",
    "NetClientSystem - Client-side networking",
    "NetServerSystem - Server-side networking",
    "BlockData & BlockMesh - Voxel/block system",
    "Actions - Player and NPC actions",
    "Commands - Debug and game commands",
    "Random - Deterministic random number generator",
    "Physics engines (Rapier 2D/3D integration)"
  ]
}
